<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.DashboardController"
           stylesheets="/css/dashboard.css"
           styleClass="overlay"
           prefWidth="480"
           prefHeight="560">

    <VBox spacing="20"
          alignment="TOP_CENTER"
          styleClass="dialog">

        <!-- HEADER -->
        <HBox spacing="16"
              alignment="CENTER_LEFT"
              styleClass="header">

            <Label fx:id="titleLabel"
                   text="Panel lekarza"
                   styleClass="header-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- WYLOGUJ – nowy styl -->
            <Button text="Wyloguj"
                    onAction="#handleLogout"
                    styleClass="logout-button"/>
        </HBox>

        <!-- CONTENT -->
        <VBox spacing="14" styleClass="content">

            <Label text="Twoje zaplanowane terminy"
                   styleClass="section-title"/>

            <ListView fx:id="listView"
                      styleClass="card-list"
                      prefHeight="300"/>

            <!-- ACTION BAR -->
            <HBox spacing="14" alignment="CENTER">
                <Button text="Dodaj termin"
                        onAction="#handleAdd"
                        styleClass="primary-button"/>

                <Button text="Usuń termin"
                        onAction="#handleDelete"
                        styleClass="secondary-button"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>
