<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="app.AddScheduleController"
           stylesheets="/css/add-schedule.css"
           styleClass="overlay"
           prefWidth="420"
           prefHeight="360">

    <VBox spacing="20"
          alignment="TOP_CENTER"
          styleClass="dialog">

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" styleClass="header">
            <Label text="Dodaj termin" styleClass="header-title"/>
        </HBox>

        <!-- CONTENT -->
        <VBox spacing="14" styleClass="content">

            <!-- DATA -->
            <VBox spacing="6">
                <Label text="Data" styleClass="field-label"/>
                <DatePicker fx:id="datePicker" styleClass="input"/>
            </VBox>

            <!-- GODZINA (SAMSUNG STYLE) -->
            <VBox spacing="6">
                <Label text="Godzina" styleClass="field-label"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Spinner fx:id="hourSpinner" styleClass="time-spinner"/>
                    <Label text=":" styleClass="time-separator"/>
                    <Spinner fx:id="minuteSpinner" styleClass="time-spinner"/>
                </HBox>
            </VBox>

            <!-- MESSAGE -->
            <Label fx:id="message" styleClass="error-label"/>

            <!-- ACTIONS -->
            <HBox spacing="14" alignment="CENTER">
                <Button text="Dodaj"
                        onAction="#handleAdd"
                        styleClass="primary-button"/>

                <Button text="Anuluj"
                        onAction="#handleCancel"
                        styleClass="secondary-button"/>
            </HBox>

        </VBox>
    </VBox>
</StackPane>
